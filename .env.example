# ── LLM Providers ─────────────────────────────────────────────────
GROQ_API_KEY=YOUR_GROQ_API_KEY
OPENAI_API_KEY=                        # optional fallback provider

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print('sentri_' + secrets.token_hex(32))"
GATEWAY_ADMIN_KEY=sentri_your_admin_key_here

# ── Domain / Role Configuration ───────────────────────────────────
# This controls what Sentri is a gateway FOR.
# Change these two settings to repurpose Sentri for any domain.
#
# DEFAULT_SYSTEM_PROMPT: the role instruction sent to the LLM on every request.
# Examples:
#   "You are a helpful DSA tutor."                         ← default
#   "You are a customer support agent for Acme Corp."
#   "You are a medical information assistant."
#   "You are a Python programming tutor."
DEFAULT_SYSTEM_PROMPT=You are a helpful DSA tutor.
#
# DOMAIN_TOPICS: comma-separated list of topics the gateway will ALLOW.
# Requests that don't match any topic are blocked by the domain policy.
# Leave this unset to use the built-in DSA topic list.
# Examples:
#   DOMAIN_TOPICS=python programming,web development,REST APIs,databases
#   DOMAIN_TOPICS=cardiology,oncology,pharmacology,clinical trials
#   DOMAIN_TOPICS=customer orders,refunds,shipping,product questions
DOMAIN_TOPICS=python programming,web development,REST APIs,databases
#
# DOMAIN_THRESHOLD: cosine similarity cutoff (0.0–1.0).
# Lower = more permissive (allows more topics through).
# Higher = stricter (only very on-topic queries pass).
# Default 0.30 works well for most use cases.
DOMAIN_THRESHOLD=0.30

# ── Cache ─────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.85
CACHE_TTL=3600

# ── Guardrails ────────────────────────────────────────────────────
ENABLE_PII_DETECTION=true
ENABLE_TOXICITY_CHECK=true
ENABLE_DOMAIN_POLICY=true

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ── Circuit Breaker ───────────────────────────────────────────────
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_TIMEOUT=60.0

# ── App ───────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
